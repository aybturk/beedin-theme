<section class="product-main" id="product-main-{{ section.id }}">
  <div class="product-main__inner">

    <!-- Left: Gallery -->
    <div class="product-main__gallery" id="product-gallery">
      {%- if product.images.size > 0 -%}
        {%- for image in product.images -%}
          <div class="product-main__gallery-item{% if forloop.first %} product-main__gallery-item--primary{% endif %}">
            <img
              src="{{ image | image_url: width: 1200 }}"
              srcset="
                {{ image | image_url: width: 600 }} 600w,
                {{ image | image_url: width: 900 }} 900w,
                {{ image | image_url: width: 1200 }} 1200w
              "
              sizes="(max-width: 768px) 100vw, 55vw"
              alt="{{ image.alt | default: product.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="product-main__gallery-image"
            >
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="product-main__gallery-placeholder">
          <div class="product-main__gallery-placeholder-inner"></div>
        </div>
      {%- endif -%}
    </div>

    <!-- Right: Product Info (sticky) -->
    <div class="product-main__info" id="product-info">

      <!-- Breadcrumb -->
      {% render 'breadcrumb' %}

      <!-- Vendor -->
      {%- if section.settings.show_vendor and product.vendor != blank -%}
        <p class="product-main__vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <!-- Title -->
      <h1 class="product-main__title">{{ product.title }}</h1>

      <!-- Price -->
      <div class="product-main__price" id="product-price">
        {% render 'price', product: product %}
      </div>

      <!-- Short Description (first paragraph) -->
      {%- if product.description != blank -%}
        {%- assign desc_paragraphs = product.description | split: '</p>' -%}
        {%- if desc_paragraphs.size > 0 -%}
          <div class="product-main__excerpt">{{ desc_paragraphs.first | append: '</p>' }}</div>
        {%- endif -%}
      {%- endif -%}

      <!-- Variant Selector -->
      {%- unless product.has_only_default_variant -%}
        <div class="product-main__variants">
          {%- for option in product.options_with_values -%}
            <div class="product-main__option">
              <label class="product-main__option-label">
                {{ option.name }}
                {%- if option.name == 'Color' or option.name == 'Colour' -%}
                  : <span class="product-main__selected-value" id="selected-{{ option.name | handle }}">{{ option.selected_value }}</span>
                {%- endif -%}
              </label>
              <div class="product-main__option-values">
                {%- for value in option.values -%}
                  <label class="product-main__option-btn{% if option.selected_value == value %} is-selected{% endif %}">
                    <input
                      type="radio"
                      name="{{ option.name }}"
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}checked{% endif %}
                      class="product-main__option-radio visually-hidden"
                      data-option-index="{{ forloop.parentloop.index0 }}"
                    >
                    {% render 'color-swatch', option: option, value: value %}
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      <!-- Add to Cart Form -->
      <div class="product-main__atc-wrap">
        {%- form 'product', product, id: 'product-form-{{ section.id }}', novalidate: true -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="product-variant-id-{{ section.id }}">

          {%- if section.settings.show_quantity -%}
            <div class="product-main__quantity">
              <label for="quantity-{{ section.id }}" class="product-main__quantity-label">{{ 'products.product.quantity' | t }}</label>
              <div class="quantity-stepper">
                <button type="button" class="quantity-stepper__btn quantity-stepper__btn--minus" aria-label="Decrease quantity" data-quantity-target="quantity-{{ section.id }}">
                  {% render 'icon', name: 'minus' %}
                </button>
                <input
                  type="number"
                  name="quantity"
                  id="quantity-{{ section.id }}"
                  value="1"
                  min="1"
                  class="quantity-stepper__input"
                  aria-label="{{ 'products.product.quantity' | t }}"
                >
                <button type="button" class="quantity-stepper__btn quantity-stepper__btn--plus" aria-label="Increase quantity" data-quantity-target="quantity-{{ section.id }}">
                  {% render 'icon', name: 'plus' %}
                </button>
              </div>
            </div>
          {%- endif -%}

          <button
            type="submit"
            name="add"
            class="btn btn--primary product-main__atc-btn"
            {%- if product.selected_or_first_available_variant.available == false -%}
              disabled
            {%- endif -%}
          >
            {%- if product.selected_or_first_available_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>
        {%- endform -%}
      </div>

      <!-- Tags -->
      {%- if section.settings.show_tags and product.tags.size > 0 -%}
        {%- assign structured_prefixes = 'category:,material:,room:,style:' | split: ',' -%}
        {%- assign has_structured_tags = false -%}
        {%- for tag in product.tags -%}
          {%- for prefix in structured_prefixes -%}
            {%- if tag contains prefix -%}
              {%- assign has_structured_tags = true -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}

        {%- if has_structured_tags -%}
          <div class="product-main__tags">
            {%- for tag in product.tags -%}
              {%- for prefix in structured_prefixes -%}
                {%- if tag contains prefix -%}
                  {%- assign tag_label = tag | remove: prefix | replace: '-', ' ' | capitalize -%}
                  {%- assign tag_prefix_label = prefix | remove: ':' | capitalize -%}
                  <span class="product-tag">
                    <span class="product-tag__prefix">{{ tag_prefix_label }}:</span>
                    <a href="{{ collection.url | default: routes.all_products_collection_url }}/{{ tag | url_encode }}" class="product-tag__value">{{ tag_label }}</a>
                  </span>
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      <!-- Accordions -->
      <div class="product-main__accordions">

        {%- if product.description != blank -%}
          <details class="accordion" open>
            <summary class="accordion__trigger">
              <span>{{ section.settings.accordion_description_title | default: 'Description' }}</span>
              <span class="accordion__icon">{% render 'icon', name: 'plus' %}</span>
            </summary>
            <div class="accordion__content rte">
              {{ product.description }}
            </div>
          </details>
        {%- endif -%}

        {%- if section.settings.accordion_details_content != blank -%}
          <details class="accordion">
            <summary class="accordion__trigger">
              <span>{{ section.settings.accordion_details_title | default: 'Details & Materials' }}</span>
              <span class="accordion__icon">{% render 'icon', name: 'plus' %}</span>
            </summary>
            <div class="accordion__content rte">
              {{ section.settings.accordion_details_content }}
            </div>
          </details>
        {%- else -%}
          <details class="accordion">
            <summary class="accordion__trigger">
              <span>{{ section.settings.accordion_details_title | default: 'Details & Materials' }}</span>
              <span class="accordion__icon">{% render 'icon', name: 'plus' %}</span>
            </summary>
            <div class="accordion__content">
              {%- if product.metafields.custom.materials != blank -%}
                {{ product.metafields.custom.materials }}
              {%- else -%}
                <p>Details and materials will appear here.</p>
              {%- endif -%}
            </div>
          </details>
        {%- endif -%}

        <details class="accordion">
          <summary class="accordion__trigger">
            <span>{{ section.settings.accordion_shipping_title | default: 'Shipping & Returns' }}</span>
            <span class="accordion__icon">{% render 'icon', name: 'plus' %}</span>
          </summary>
          <div class="accordion__content">
            {%- if section.settings.accordion_shipping_content != blank -%}
              {{ section.settings.accordion_shipping_content }}
            {%- else -%}
              <p>Free shipping on orders over ₺500. Standard delivery 3–5 business days. Easy 30-day returns on all items.</p>
            {%- endif -%}
          </div>
        </details>

      </div>

    </div>

  </div>
</section>

<style>
  .product-main {
    padding-top: var(--space-7);
    padding-bottom: var(--section-gap);
  }

  .product-main__inner {
    display: grid;
    grid-template-columns: 55fr 45fr;
    align-items: start;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--page-gutter);
    gap: var(--space-10);
  }

  @media (max-width: 1024px) {
    .product-main__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-7);
    }
  }

  @media (max-width: 768px) {
    .product-main__inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  /* Gallery */
  .product-main__gallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .product-main__gallery-item {
    overflow: hidden;
  }

  .product-main__gallery-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--duration-crawl) var(--ease-out-expo);
  }

  .product-main__gallery-item:hover .product-main__gallery-image {
    transform: scale(1.02);
  }

  .product-main__gallery-placeholder-inner {
    aspect-ratio: 4 / 5;
    background: var(--color-bg-alt);
  }

  /* Info (sticky) */
  .product-main__info {
    position: sticky;
    top: calc(var(--header-height) + var(--space-6));
    max-height: calc(100vh - var(--header-height) - var(--space-10));
    overflow-y: auto;
    scrollbar-width: thin;
    padding-bottom: var(--space-7);
  }

  @media (max-width: 768px) {
    .product-main__info {
      position: static;
      max-height: none;
      overflow-y: visible;
    }
  }

  .product-main__vendor {
    font-family: var(--font-body);
    font-size: var(--type-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-accent);
    margin: var(--space-3) 0 var(--space-4);
  }

  .product-main__title {
    font-family: var(--font-display);
    font-size: var(--type-xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0 0 var(--space-5) 0;
    line-height: var(--leading-snug);
  }

  .product-main__price {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .product-main__excerpt {
    font-family: var(--font-body);
    font-size: var(--type-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-6);
  }

  /* Variants */
  .product-main__variants {
    margin-bottom: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .product-main__option-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--type-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .product-main__selected-value {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }

  .product-main__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .product-main__option-btn {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    font-family: var(--font-body);
    font-size: var(--type-sm);
    color: var(--color-text);
    cursor: pointer;
    transition: border-color var(--duration-fast), background var(--duration-fast);
  }

  .product-main__option-btn.is-selected {
    border-color: var(--color-text);
    background: var(--color-text);
    color: var(--color-text-inverse);
  }

  .product-main__option-btn:hover:not(.is-selected) {
    border-color: var(--color-text-muted);
  }

  /* Quantity */
  .product-main__quantity {
    margin-bottom: var(--space-4);
  }

  .product-main__quantity-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--type-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .quantity-stepper {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border);
  }

  .quantity-stepper__btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    transition: background var(--duration-fast);
  }

  .quantity-stepper__btn:hover {
    background: var(--color-bg-alt);
  }

  .quantity-stepper__btn svg {
    width: 16px;
    height: 16px;
  }

  .quantity-stepper__input {
    width: 56px;
    height: 44px;
    text-align: center;
    border: none;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--type-base);
    color: var(--color-text);
    outline: none;
    -moz-appearance: textfield;
  }

  .quantity-stepper__input::-webkit-outer-spin-button,
  .quantity-stepper__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* ATC */
  .product-main__atc-wrap {
    margin-bottom: var(--space-6);
  }

  .product-main__atc-btn {
    width: 100%;
    justify-content: center;
    margin-top: var(--space-4);
    font-size: var(--type-sm);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    height: 56px;
  }

  /* Tags */
  .product-main__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .product-tag {
    font-family: var(--font-body);
    font-size: var(--type-xs);
    color: var(--color-text-muted);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    display: inline-flex;
    gap: var(--space-1);
  }

  .product-tag__prefix {
    font-weight: 500;
  }

  .product-tag__value {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .product-tag__value:hover {
    color: var(--color-text);
  }

  /* Accordions */
  .product-main__accordions {
    margin-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .accordion {
    border-bottom: 1px solid var(--color-border);
  }

  .accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-5) 0;
    font-family: var(--font-body);
    font-size: var(--type-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .accordion__trigger::-webkit-details-marker {
    display: none;
  }

  .accordion__icon {
    flex-shrink: 0;
    transition: transform var(--duration-fast);
    color: var(--color-text-muted);
  }

  .accordion__icon svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  details[open] .accordion__icon {
    transform: rotate(45deg);
  }

  .accordion__content {
    padding: 0 0 var(--space-6);
    font-family: var(--font-body);
    font-size: var(--type-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
  }

  .accordion__content p {
    margin: 0 0 var(--space-3);
  }

  .accordion__content p:last-child {
    margin-bottom: 0;
  }
</style>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show structured tags as pills",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "header",
      "content": "Accordion Labels"
    },
    {
      "type": "text",
      "id": "accordion_description_title",
      "label": "Description accordion label",
      "default": "Description"
    },
    {
      "type": "text",
      "id": "accordion_details_title",
      "label": "Details accordion label",
      "default": "Details & Materials"
    },
    {
      "type": "richtext",
      "id": "accordion_details_content",
      "label": "Details content (if not from metafields)"
    },
    {
      "type": "text",
      "id": "accordion_shipping_title",
      "label": "Shipping accordion label",
      "default": "Shipping & Returns"
    },
    {
      "type": "richtext",
      "id": "accordion_shipping_content",
      "label": "Shipping content"
    }
  ],
  "presets": [
    {
      "name": "Product Main",
      "category": "Product"
    }
  ]
}
{% endschema %}
