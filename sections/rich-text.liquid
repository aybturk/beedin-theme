<section class="rich-text-section" id="rich-text-{{ section.id }}">
  <div class="rich-text-section__inner">
    {%- if section.settings.heading != blank -%}
      <h1 class="rich-text-section__heading reveal">{{ section.settings.heading }}</h1>
    {%- elsif page.title != blank -%}
      <h1 class="rich-text-section__heading reveal">{{ page.title }}</h1>
    {%- endif -%}

    {%- if section.settings.content != blank -%}
      <div class="rich-text-section__content rte reveal">{{ section.settings.content }}</div>
    {%- elsif page.content != blank -%}
      <div class="rich-text-section__content rte reveal">{{ page.content }}</div>
    {%- endif -%}
  </div>
</section>

<style>
  .rich-text-section {
    padding: var(--space-10) var(--page-gutter);
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .rich-text-section__inner {
    max-width: var(--prose-max);
    margin: 0 auto;
  }

  .rich-text-section__heading {
    font-family: var(--font-display);
    font-size: var(--type-xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0 0 var(--space-7) 0;
  }

  .rich-text-section__content {
    font-family: var(--font-body);
    font-size: var(--type-base);
    color: var(--color-text);
    line-height: var(--leading-loose);
  }

  .rte h1, .rte h2, .rte h3, .rte h4 {
    font-family: var(--font-display);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .rte p {
    margin-bottom: var(--space-5);
  }

  .rte a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .rte img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: var(--space-7) 0;
  }

  .rte ul, .rte ol {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
  }

  .rte li {
    margin-bottom: var(--space-2);
  }

  .rte blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-6);
    margin: var(--space-7) 0;
    font-family: var(--font-display);
    font-size: var(--type-lg);
    font-style: italic;
    font-weight: 300;
    color: var(--color-text);
  }
</style>

{% schema %}
{
  "name": "Rich Text",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (overrides page title)"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content (overrides page content)"
    }
  ],
  "presets": [
    {
      "name": "Rich Text",
      "category": "Content"
    }
  ]
}
{% endschema %}
