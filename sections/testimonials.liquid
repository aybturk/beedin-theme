<section class="testimonials" id="testimonials-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="testimonials__header reveal">
      <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="testimonials__slider" id="testimonials-slider-{{ section.id }}" aria-live="polite">
      {%- for block in section.blocks -%}
        <div
          class="testimonials__slide{% if forloop.first %} is-active{% endif %}"
          id="testimonial-{{ section.id }}-{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
          aria-hidden="{{ forloop.first | default_unless: 'false' }}"
        >
          {%- if block.settings.quote != blank -%}
            <blockquote class="testimonials__quote">
              <p class="testimonials__quote-text">&#8220;{{ block.settings.quote }}&#8221;</p>
              {%- if block.settings.author != blank -%}
                <footer class="testimonials__author">
                  <cite>
                    {{ block.settings.author }}
                    {%- if block.settings.location != blank -%}
                      <span class="testimonials__location">— {{ block.settings.location }}</span>
                    {%- endif -%}
                  </cite>
                </footer>
              {%- endif -%}
            </blockquote>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="testimonials__controls">
        {%- for block in section.blocks -%}
          <button
            class="testimonials__dot{% if forloop.first %} is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            data-testimonial-slider="{{ section.id }}"
            aria-label="Go to testimonial {{ forloop.index }}"
            type="button"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="testimonials__empty">
      <p>Add testimonial blocks in the section settings.</p>
    </div>
  {%- endif -%}
</section>

<style>
  .testimonials {
    padding: var(--section-gap) var(--page-gutter);
    background: var(--color-bg-alt);
    text-align: center;
  }

  .testimonials__header {
    margin-bottom: var(--space-8);
  }

  .testimonials__heading {
    font-family: var(--font-body);
    font-size: var(--type-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .testimonials__slider {
    position: relative;
    max-width: 680px;
    margin: 0 auto;
    min-height: 180px;
    display: grid;
  }

  .testimonials__slide {
    grid-area: 1 / 1;
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-in-out);
    pointer-events: none;
    visibility: hidden;
  }

  .testimonials__slide.is-active {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

  .testimonials__quote-text {
    font-family: var(--font-display);
    font-size: var(--type-xl);
    font-weight: 300;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0 0 var(--space-6) 0;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .testimonials__quote-text {
      font-size: var(--type-lg);
    }
  }

  .testimonials__author {
    font-style: normal;
  }

  .testimonials__author cite {
    font-family: var(--font-body);
    font-size: var(--type-sm);
    font-style: normal;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    font-size: var(--type-xs);
  }

  .testimonials__location {
    display: block;
    color: var(--color-text-muted);
    opacity: 0.7;
    margin-top: var(--space-1);
  }

  .testimonials__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-7);
  }

  .testimonials__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color var(--duration-fast), transform var(--duration-fast);
  }

  .testimonials__dot.is-active {
    background: var(--color-accent);
    transform: scale(1.3);
  }

  .testimonials__dot:hover:not(.is-active) {
    background: var(--color-text-muted);
  }

  .testimonials__empty {
    text-align: center;
    padding: var(--space-9);
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--type-sm);
  }
</style>

<script>
  (function() {
    var slider = document.getElementById('testimonials-slider-{{ section.id }}');
    if (!slider) return;

    var slides = slider.querySelectorAll('.testimonials__slide');
    var dots = document.querySelectorAll('[data-testimonial-slider="{{ section.id }}"]');
    var currentIndex = 0;
    var autoplayTimer = null;

    function goTo(index) {
      slides[currentIndex].classList.remove('is-active');
      dots[currentIndex] && dots[currentIndex].classList.remove('is-active');
      currentIndex = (index + slides.length) % slides.length;
      slides[currentIndex].classList.add('is-active');
      dots[currentIndex] && dots[currentIndex].classList.add('is-active');
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        clearInterval(autoplayTimer);
        goTo(parseInt(this.dataset.index));
      });
    });

    if (slides.length > 1) {
      autoplayTimer = setInterval(function() {
        goTo(currentIndex + 1);
      }, {{ section.settings.autoplay_speed | default: 5000 }});
    }
  })();
</script>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Label",
      "default": "What Our Customers Say"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (ms)",
      "min": 3000,
      "max": 10000,
      "step": 500,
      "default": 5000
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "quote",
          "label": "Quote",
          "default": "Beautifully crafted pieces that bring so much warmth to our home. The quality exceeded all expectations."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Zeynep K."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location (optional)",
          "placeholder": "Istanbul, Turkey"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "Social Proof",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "Beautifully crafted pieces that bring so much warmth to our home. The quality exceeded all expectations.",
            "author": "Zeynep K.",
            "location": "Istanbul"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Every item feels considered and special. The packaging was stunning — it felt like unwrapping a gift.",
            "author": "Sara M.",
            "location": "Ankara"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "I've ordered three times now and each piece is better than the last. Beedin has become my go-to for home gifts.",
            "author": "Aylin T.",
