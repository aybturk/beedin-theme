{%- liquid
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign text_color_class = section.settings.text_color | default: 'light'
-%}

<section class="editorial-banner editorial-banner--text-{{ text_color_class }}" id="editorial-banner-{{ section.id }}">
  <div class="editorial-banner__media">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1600 }}"
        srcset="
          {{ section.settings.image | image_url: width: 800 }} 800w,
          {{ section.settings.image | image_url: width: 1200 }} 1200w,
          {{ section.settings.image | image_url: width: 1600 }} 1600w,
          {{ section.settings.image | image_url: width: 2400 }} 2400w
        "
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
        loading="lazy"
        class="editorial-banner__image"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      <div class="editorial-banner__placeholder"></div>
    {%- endif -%}
    <div class="editorial-banner__overlay" style="--overlay-opacity: {{ overlay_opacity }};"></div>
  </div>

  <div class="editorial-banner__content reveal">
    {%- if section.settings.eyebrow != blank -%}
      <p class="editorial-banner__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="editorial-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="editorial-banner__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_url | default: '/collections/all' }}"
        class="btn {% if text_color_class == 'light' %}btn--ghost-light{% else %}btn--primary{% endif %} editorial-banner__cta"
      >
        {{ section.settings.button_label }}
        {% render 'icon', name: 'arrow-right' %}
      </a>
    {%- endif -%}
  </div>
</section>

<style>
  .editorial-banner {
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.min_height | default: 70 }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .editorial-banner__media {
    position: absolute;
    inset: 0;
  }

  .editorial-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .editorial-banner__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-dark);
  }

  .editorial-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(28, 25, 23, var(--overlay-opacity, 0.4));
  }

  .editorial-banner__content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 700px;
    padding: var(--space-10) var(--page-gutter);
  }

  .editorial-banner--text-light .editorial-banner__eyebrow {
    color: rgba(247, 244, 240, 0.75);
  }

  .editorial-banner--text-dark .editorial-banner__eyebrow {
    color: var(--color-accent);
  }

  .editorial-banner__eyebrow {
    font-family: var(--font-body);
    font-size: var(--type-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    margin: 0 0 var(--space-4) 0;
  }

  .editorial-banner--text-light .editorial-banner__heading {
    color: var(--color-text-inverse);
  }

  .editorial-banner--text-dark .editorial-banner__heading {
    color: var(--color-text);
  }

  .editorial-banner__heading {
    font-family: var(--font-display);
    font-size: var(--type-2xl);
    font-weight: 300;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-5) 0;
  }

  .editorial-banner--text-light .editorial-banner__subheading {
    color: rgba(247, 244, 240, 0.8);
  }

  .editorial-banner--text-dark .editorial-banner__subheading {
    color: var(--color-text-muted);
  }

  .editorial-banner__subheading {
    font-family: var(--font-body);
    font-size: var(--type-md);
    line-height: var(--leading-loose);
    margin: 0 0 var(--space-7) 0;
  }

  .editorial-banner__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
  }
</style>

{% schema %}
{
  "name": "Editorial Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 70,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "vh"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made for Your Home"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover pieces that transform everyday spaces into something extraordinary."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "options": [
        { "value": "light", "label": "Light (on dark images)" },
        { "value": "dark", "label": "Dark (on light images)" }
      ],
      "default": "light"
    }
  ],
  "presets": [
    {
      "name": "Editorial Banner",
      "category": "Banners"
    }
  ]
}
{% endschema %}
