<section class="contact-section" id="contact-form-{{ section.id }}">
  <div class="contact-section__inner">
    <div class="contact-section__header reveal">
      <h1 class="contact-section__heading">{{ section.settings.heading | default: 'Get in Touch' }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="contact-section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="contact-section__layout">
      <!-- Contact Form -->
      <div class="contact-section__form-wrap reveal">
        {% form 'contact', id: 'contact-form' %}
          {%- if form.posted_successfully? -%}
            <div class="contact-section__success">
              <p>{{ section.settings.success_message | default: 'Thank you for reaching out! We\'ll respond within 1–2 business days.' }}</p>
            </div>
          {%- else -%}
            {%- if form.errors -%}
              <div class="contact-section__errors">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="contact-section__fields">
              <div class="contact-section__field">
                <label for="contact-name" class="contact-section__label">{{ 'contact.form.name' | t }}</label>
                <input
                  type="text"
                  name="contact[name]"
                  id="contact-name"
                  value="{{ form.name }}"
                  required
                  class="contact-section__input"
                  autocomplete="name"
                >
              </div>

              <div class="contact-section__field">
                <label for="contact-email" class="contact-section__label">{{ 'contact.form.email' | t }}</label>
                <input
                  type="email"
                  name="contact[email]"
                  id="contact-email"
                  value="{{ form.email }}"
                  required
                  class="contact-section__input"
                  autocomplete="email"
                >
              </div>

              {%- if section.settings.show_phone -%}
                <div class="contact-section__field">
                  <label for="contact-phone" class="contact-section__label">{{ 'contact.form.phone' | t }}</label>
                  <input
                    type="tel"
                    name="contact[phone]"
                    id="contact-phone"
                    value="{{ form.phone }}"
                    class="contact-section__input"
                    autocomplete="tel"
                  >
                </div>
              {%- endif -%}

              <div class="contact-section__field contact-section__field--full">
                <label for="contact-message" class="contact-section__label">{{ 'contact.form.message' | t }}</label>
                <textarea
                  name="contact[body]"
                  id="contact-message"
                  rows="6"
                  required
                  class="contact-section__textarea"
                >{{ form.body }}</textarea>
              </div>
            </div>

            <button type="submit" class="btn btn--primary contact-section__submit">
              {{ 'contact.form.submit' | t }}
            </button>
          {%- endif -%}
        {% endform %}
      </div>

      <!-- Contact Info -->
      {%- if section.settings.show_info -%}
        <div class="contact-section__info reveal">
          {%- if section.settings.info_heading != blank -%}
            <h2 class="contact-section__info-heading">{{ section.settings.info_heading }}</h2>
          {%- endif -%}
          {%- if section.settings.info_content != blank -%}
            <div class="contact-section__info-content rte">{{ section.settings.info_content }}</div>
          {%- endif -%}
          {%- if settings.store_email != blank -%}
            <a href="mailto:{{ settings.store_email }}" class="contact-section__email">{{ settings.store_email }}</a>
          {%- endif -%}
          {%- if settings.store_address != blank -%}
            <div class="contact-section__address rte">{{ settings.store_address }}</div>
          {%- endif -%}
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" class="contact-section__social-link" target="_blank" rel="noopener noreferrer">
              {% render 'icon', name: 'instagram' %}
              <span>Instagram</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  .contact-section {
    padding: var(--space-10) var(--page-gutter);
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .contact-section__header {
    margin-bottom: var(--space-9);
    max-width: var(--prose-max);
  }

  .contact-section__heading {
    font-family: var(--font-display);
    font-size: var(--type-xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0 0 var(--space-4) 0;
  }

  .contact-section__subheading {
    font-family: var(--font-body);
    font-size: var(--type-base);
    color: var(--color-text-muted);
    margin: 0;
    line-height: var(--leading-loose);
  }

  .contact-section__layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-10);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .contact-section__layout {
      grid-template-columns: 1fr;
    }
  }

  .contact-section__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }

  @media (max-width: 600px) {
    .contact-section__fields {
      grid-template-columns: 1fr;
    }
  }

  .contact-section__field--full {
    grid-column: 1 / -1;
  }

  .contact-section__label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--type-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .contact-section__input,
  .contact-section__textarea {
    width: 100%;
    padding: var(--space-4) var(--space-4);
    border: 1px solid var(--color-border);
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--type-base);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--duration-fast);
    box-sizing: border-box;
  }

  .contact-section__input:focus,
  .contact-section__textarea:focus {
    border-color: var(--color-accent);
  }

  .contact-section__textarea {
    resize: vertical;
    min-height: 160px;
  }

  .contact-section__submit {
    min-width: 200px;
  }

  .contact-section__success {
    background: var(--color-bg-alt);
    padding: var(--space-6);
    border-left: 2px solid var(--color-accent);
    font-family: var(--font-body);
    font-size: var(--type-base);
    color: var(--color-text);
  }

  .contact-section__errors {
    background: rgba(192, 57, 43, 0.08);
    border: 1px solid var(--color-error);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-5);
    font-family: var(--font-body);
    font-size: var(--type-sm);
    color: var(--color-error);
  }

  .contact-section__info-heading {
    font-family: var(--font-display);
    font-size: var(--type-lg);
    font-weight: 300;
    color: var(--color-text);
    margin: 0 0 var(--space-5) 0;
  }

  .contact-section__info-content {
    font-family: var(--font-body);
    font-size: var(--type-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-5);
  }

  .contact-section__email {
    display: block;
    font-family: var(--font-body);
    font-size: var(--type-sm);
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: var(--space-4);
    transition: color var(--duration-fast);
  }

  .contact-section__email:hover {
    color: var(--color-text);
  }

  .contact-section__social-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--type-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast);
    margin-top: var(--space-5);
  }

  .contact-section__social-link:hover {
    color: var(--color-text);
  }

  .contact-section__social-link svg {
    width: 18px;
    height: 18px;
  }
</style>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "We'd love to hear from you. Fill out the form and we'll be in touch within 1–2 business days."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for reaching out! We'll respond within 1–2 business days."
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone field",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_info",
      "label": "Show contact info sidebar",
      "default": true
    },
    {
      "type": "text",
      "id": "info_heading",
      "label": "Info sidebar heading",
      "default": "Contact Information"
    },
    {
      "type": "richtext",
      "id": "info_content",
      "label": "Info sidebar content"
    }
  ],
  "presets": [
    {
      "name": "Contact Form",
      "category": "Contact"
    }
  ]
}
{% endschema %}
