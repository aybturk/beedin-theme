{%- liquid
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif
-%}

<section
  class="hero-fullscreen{% if settings.hero_scale_enabled %} hero-fullscreen--animated{% endif %}"
  id="hero-{{ section.id }}"
  aria-label="{{ section.settings.heading | escape }}"
>

  <!-- Background Image -->
  <div class="hero-fullscreen__media">
    {%- if has_image -%}
      <img
        src="{{ section.settings.image | image_url: width: 1600 }}"
        srcset="
          {{ section.settings.image | image_url: width: 800 }} 800w,
          {{ section.settings.image | image_url: width: 1200 }} 1200w,
          {{ section.settings.image | image_url: width: 1600 }} 1600w,
          {{ section.settings.image | image_url: width: 2400 }} 2400w
        "
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
        loading="eager"
        fetchpriority="high"
        class="hero-fullscreen__image"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      <img
        src="{{ 'hero-default.png' | asset_url }}"
        alt="{{ section.settings.heading | escape | default: shop.name }}"
        loading="eager"
        fetchpriority="high"
        class="hero-fullscreen__image"
      >
    {%- endif -%}
    <div class="hero-fullscreen__overlay" style="--overlay-opacity: {{ overlay_opacity }};"></div>
  </div>

  <!-- Content -->
  <div class="hero-fullscreen__content reveal">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero-fullscreen__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero-fullscreen__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-fullscreen__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_url | default: '/collections/all' }}"
        class="btn {% if section.settings.button_style == 'ghost' %}btn--ghost-light{% else %}btn--primary{% endif %} hero-fullscreen__cta"
      >
        <span>{{ section.settings.button_label }}</span>
        <span class="btn__icon" aria-hidden="true">{% render 'icon', name: 'arrow-right' %}</span>
      </a>
    {%- endif -%}
  </div>

</section>

<style>
  #hero-{{ section.id }} .hero-fullscreen__content {
    --hero-text-color: {{ section.settings.text_color | default: '#F7F4F0' }};
  }
</style>

{% schema %}
{
  "name": "Hero – Fullscreen",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 70,
      "step": 5,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text (small, above heading)",
      "placeholder": "New Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Warmth in Every Detail"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium home decor, curated for the modern home."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary (filled)" },
        { "value": "ghost", "label": "Ghost (outline, light)" }
      ],
      "default": "ghost"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F7F4F0"
    }
  ],
  "presets": [
    {
      "name": "Hero – Fullscreen",
      "category": "Hero"
    }
  ]
}
{% endschema %}
