{%- assign layout = section.settings.layout | default: 'image_left' -%}

<section class="hero-split hero-split--{{ layout }} reveal" id="hero-split-{{ section.id }}">

  <!-- Image Side -->
  <div class="hero-split__media">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 900 }}"
        srcset="
          {{ section.settings.image | image_url: width: 600 }} 600w,
          {{ section.settings.image | image_url: width: 900 }} 900w,
          {{ section.settings.image | image_url: width: 1200 }} 1200w
        "
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
        loading="lazy"
        class="hero-split__image"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      <div class="hero-split__placeholder"></div>
    {%- endif -%}
  </div>

  <!-- Text Side -->
  <div class="hero-split__content">
    <div class="hero-split__content-inner">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero-split__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="hero-split__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="hero-split__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_url | default: '/collections/all' }}"
          class="btn btn--primary hero-split__cta"
        >
          {{ section.settings.button_label }}
          {% render 'icon', name: 'arrow-right' %}
        </a>
      {%- endif -%}
    </div>
  </div>

</section>

<style>
  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }

  .hero-split--image_right {
    direction: rtl;
  }

  .hero-split--image_right > * {
    direction: ltr;
  }

  @media (max-width: 768px) {
    .hero-split {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .hero-split--image_right > * {
      direction: ltr;
    }
  }

  .hero-split__media {
    overflow: hidden;
    position: relative;
  }

  .hero-split__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-crawl) var(--ease-out-expo);
  }

  .hero-split:hover .hero-split__image {
    transform: scale(1.03);
  }

  .hero-split__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-bg-alt);
    min-height: 60vh;
  }

  .hero-split__content {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-10) var(--space-9);
    background: var(--color-bg);
  }

  @media (max-width: 1024px) {
    .hero-split__content {
      padding: var(--space-8) var(--space-7);
    }
  }

  @media (max-width: 768px) {
    .hero-split__content {
      padding: var(--space-8) var(--page-gutter);
    }
  }

  .hero-split__content-inner {
    max-width: 480px;
  }

  .hero-split__eyebrow {
    font-family: var(--font-body);
    font-size: var(--type-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 var(--space-4) 0;
  }

  .hero-split__heading {
    font-family: var(--font-display);
    font-size: var(--type-xl);
    font-weight: 300;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0 0 var(--space-5) 0;
  }

  .hero-split__text {
    font-family: var(--font-body);
    font-size: var(--type-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-7);
  }

  .hero-split__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
  }
</style>

{% schema %}
{
  "name": "Hero – Split",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "image_left", "label": "Image left" },
        { "value": "image_right", "label": "Image right" }
      ],
      "default": "image_left"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "placeholder": "New Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted With Intention"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Each piece in our collection is chosen for its beauty, craftsmanship, and the warmth it brings to your space.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero – Split",
      "category": "Hero"
    }
  ]
}
{% endschema %}
