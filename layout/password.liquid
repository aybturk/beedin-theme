<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400&display=swap">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <title>{{ shop.name }} — Coming Soon</title>
</head>

<body class="template-password" style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:100vh; background:var(--color-bg); margin:0; padding:var(--space-8) var(--page-gutter); text-align:center;">

  <div class="password-page" style="max-width:480px; width:100%;">

    <h1 class="password-logo" style="font-family:var(--font-display); font-size:var(--type-xl); letter-spacing:var(--tracking-wider); font-weight:300; margin-bottom:var(--space-7);">
      {{ shop.name | upcase }}
    </h1>

    <p style="font-family:var(--font-body); font-size:var(--type-base); color:var(--color-text-muted); margin-bottom:var(--space-8); line-height:var(--leading-loose);">
      Something beautiful is on its way.<br>We're crafting every detail.
    </p>

    {% if shop.password_message != blank %}
      <p style="font-family:var(--font-body); color:var(--color-text-muted); font-size:var(--type-sm); margin-bottom:var(--space-7);">{{ shop.password_message }}</p>
    {% endif %}

    <details style="margin-bottom:var(--space-6);">
      <summary style="font-family:var(--font-body); font-size:var(--type-sm); letter-spacing:var(--tracking-wide); text-transform:uppercase; cursor:pointer; color:var(--color-text-muted); list-style:none; margin-bottom:var(--space-5);">
        {{ 'general.password.login' | t }}
      </summary>
      {% form 'storefront_password' %}
        <div style="display:flex; gap:var(--space-3); margin-top:var(--space-4);">
          <input
            type="password"
            name="password"
            id="password"
            placeholder="Password"
            style="flex:1; padding:var(--space-4) var(--space-5); border:1px solid var(--color-border); background:transparent; font-family:var(--font-body); font-size:var(--type-base); color:var(--color-text); outline:none;"
            autofocus
          >
          <button type="submit" class="btn btn--primary">{{ 'general.password.submit' | t }}</button>
        </div>
        {% if form.errors %}
          <p style="color:var(--color-error); font-size:var(--type-sm); margin-top:var(--space-3);">Incorrect password.</p>
        {% endif %}
      {% endform %}
    </details>

    <p style="font-family:var(--font-body); font-size:var(--type-xs); color:var(--color-text-muted); margin-top:var(--space-8);">
      Powered by <a href="https://shopify.com" style="color:inherit;">Shopify</a>
    </p>

  </div>

</body>
</html>
