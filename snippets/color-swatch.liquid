{%- liquid
  comment
    Usage: {% render 'color-swatch', option: option, value: value %}
    Renders a color swatch or text option button.
    For Color options: attempts to match value to a CSS color name or hex.
    For non-color options: renders as a text label.
  endcomment

  assign option_name_lower = option.name | downcase
  assign is_color_option = false
  if option_name_lower == 'color' or option_name_lower == 'colour' or option_name_lower == 'renk'
    assign is_color_option = true
  endif

  assign value_handle = value | handleize
-%}

{%- if is_color_option -%}
  {%- liquid
    comment
      Map common color names to CSS values.
      In production, this is typically fed from a metafield or JSON file.
      This skeleton maps the most common values.
    endcomment
    case value_handle
      when 'white'
        assign swatch_color = '#FFFFFF'
      when 'black'
        assign swatch_color = '#1C1917'
      when 'beige', 'cream'
        assign swatch_color = '#F5F0E8'
      when 'brown'
        assign swatch_color = '#8B5E3C'
      when 'walnut'
        assign swatch_color = '#6B4226'
      when 'oak'
        assign swatch_color = '#B07D55'
      when 'gold'
        assign swatch_color = '#C9A84C'
      when 'brass'
        assign swatch_color = '#B5A642'
      when 'copper'
        assign swatch_color = '#B87333'
      when 'silver'
        assign swatch_color = '#C0C0C0'
      when 'grey', 'gray'
        assign swatch_color = '#9E9E9E'
      when 'dark-grey', 'dark-gray', 'charcoal'
        assign swatch_color = '#4A4A4A'
      when 'natural'
        assign swatch_color = '#E8DCC8'
      when 'terracotta'
        assign swatch_color = '#C97B55'
      when 'green', 'sage'
        assign swatch_color = '#87A878'
      when 'navy', 'dark-blue'
        assign swatch_color = '#2C3E6B'
      when 'dusty-pink', 'pink', 'rose'
        assign swatch_color = '#D4A5A5'
      else
        assign swatch_color = nil
    endcase
  -%}

  {%- if swatch_color -%}
    <span
      class="color-swatch"
      style="--swatch-color: {{ swatch_color }};"
      title="{{ value | escape }}"
      aria-label="{{ value | escape }}"
    >
      <span class="color-swatch__inner"></span>
    </span>
  {%- else -%}
    <span class="option-btn__label">{{ value }}</span>
  {%- endif -%}

{%- else -%}
  <span class="option-btn__label">{{ value }}</span>
{%- endif -%}

<style>
  .color-swatch {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    padding: 2px;
    cursor: pointer;
    transition: border-color var(--duration-fast);
  }

  .product-main__option-btn.is-selected .color-swatch {
    border-color: var(--color-text);
  }

  .color-swatch__inner {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--swatch-color, var(--color-border));
    border: 1px solid rgba(0, 0, 0, 0.1);
    display: block;
  }

  .option-btn__label {
    display: block;
    padding: 0 var(--space-2);
    font-family: var(--font-body);
    font-size: var(--type-sm);
  }
</style>
