{%- liquid
  assign seo_title = page_title | default: shop.name
  assign seo_description = page_description | default: shop.description | default: ''
  assign seo_image = nil

  if settings.logo != blank
    assign seo_image = settings.logo | image_url: width: 1200
  endif

  if template.name == 'product' and product.featured_image != blank
    assign seo_image = product.featured_image | image_url: width: 1200
  elsif template.name == 'collection' and collection.image != blank
    assign seo_image = collection.image | image_url: width: 1200
  elsif template.name == 'article' and article.image != blank
    assign seo_image = article.image | image_url: width: 1200
  endif

  assign seo_url = canonical_url | default: request.origin
-%}

<!-- Primary Meta -->
<title>{{ seo_title }}</title>
{%- if seo_description != blank -%}
  <meta name="description" content="{{ seo_description | strip_html | truncate: 160 | escape }}">
{%- endif -%}
<link rel="canonical" href="{{ seo_url }}">

<!-- Open Graph -->
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:type" content="{% if template.name == 'product' %}product{% elsif template.name == 'article' %}article{% else %}website{% endif %}">
<meta property="og:title" content="{{ seo_title | escape }}">
{%- if seo_description != blank -%}
  <meta property="og:description" content="{{ seo_description | strip_html | truncate: 200 | escape }}">
{%- endif -%}
<meta property="og:url" content="{{ seo_url }}">
{%- if seo_image -%}
  <meta property="og:image" content="https:{{ seo_image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
{%- endif -%}

<!-- Twitter Card -->
<meta name="twitter:card" content="{% if seo_image %}summary_large_image{% else %}summary{% endif %}">
<meta name="twitter:title" content="{{ seo_title | escape }}">
{%- if seo_description != blank -%}
  <meta name="twitter:description" content="{{ seo_description | strip_html | truncate: 200 | escape }}">
{%- endif -%}
{%- if seo_image -%}
  <meta name="twitter:image" content="https:{{ seo_image }}">
{%- endif -%}

<!-- Product Schema (JSON-LD) -->
{%- if template.name == 'product' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | json }},
      "url": {{ canonical_url | json }},
      {% if product.featured_image %}
      "image": ["https:{{ product.featured_image | image_url: width: 1200 }}"],
      {% endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "lowPrice": {{ product.price_min | money_without_currency }},
        "highPrice": {{ product.price_max | money_without_currency }},
        "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
      }
    }
  </script>
{%- endif -%}

{%- if template.name == 'article' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": {{ article.title | json }},
      "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S' }}",
      "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S' }}",
      "author": {
        "@type": "Person",
        "name": {{ article.author | json }}
      }
    }
  </script>
{%- endif -%}
