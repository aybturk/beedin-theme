{%- comment -%}
  Usage: {% render 'icon', name: 'cart' %}
  Supported: cart, search, menu, close, arrow-right, arrow-left, instagram, pinterest,
             chevron-down, plus, minus, facebook, check, user, heart, share
  Unknown names render nothing (no error).
{%- endcomment -%}

